<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= pageTitle %> | Joe's Coffee
    </title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/layout.css">
</head>

<body>
    <%- include('partials/navbar', { pageHeading }) %>
        <main>
            <section id="product-hero">
                <!-- First row -->
                <div class="row">
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/forge-blend.png" alt="Coffee bag">
                            <h4>Forge Espresso</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/sundial-blend.png" alt="Coffee bag">
                            <h4>Sundial House Blend</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/midnight-blend.png" alt="Coffee bag">
                            <h4>Midnight Dark Roast</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                </div>
                <!-- Second row -->
                <div class="row">
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/ember-blend.png" alt="Coffee bag">
                            <h4>Ember Medium Roast</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/special-blend.png" alt="Coffee bag">
                            <h4>Pony Boy Special</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/gift-card.png" alt="Coffee bag">
                            <h4>Gift card</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="container">
                        <a class="button green-button" href="#footer-hero">REQUEST DELIVERY</a>
                    </div>
                </div>
                </div>
            </section>
            <hr class="centered" style="opacity: 0.1; max-width: 720px; margin-top: 25px; color: #2F5249;">
            <section id="about-hero">
                <div class="row">
                    <div class="col col-sm-12 col-6">
                        <div class="container about-text">
                            <div class="left">
                                <h2>About us</h2>
                                <p>
                                    Joe's is a small craft artisan roastery built on passion, precision, and the pursuit
                                    of the perfect cup. We roast in small
                                    batches to ensure every bean tells its story—bold, balanced, and beautifully fresh.
                                </p><br>

                                <p>
                                    Our roots run deep in the local community. From sourcing ethically to supporting
                                    nearby growers and makers, we believe coffee is more than a beverage—it's a bridge.
                                    Whether you're grabbing a morning pour or lingering for conversation, Joe's is where
                                    neighbors become regulars and regulars become family.
                                </p><br>

                                <p>
                                    Freshness is our promise—across all four of our locations. Every roast is timed to
                                    peak flavor, every bag sealed with care. We don’t stock shelves—we stock moments.
                                    From origin to cup, we keep it simple, honest, and always fresh, no matter which
                                    Joe’s you call home.
                                </p><br>

                                <p>
                                    Come for the coffee. Stay for the community.
                                </p>

                            </div>
                        </div>
                    </div>
                    <div class="col col-6 col-sm-12">
                        <div class="container centered">
                            <img src="/images/about-pfp.jpg" alt="Profile picture"
                                style="border-radius: 100px; max-width: 60%; height: auto; display: block; margin: 0 auto;">
                            <img src="/images/signature.png" width="350px" alt="Signature"
                                style="display: block; margin: 20px auto 0 auto;">
                        </div>
                    </div>

                </div>
            </section>
            <section id="loyalty-hero">
                <div class="qr-section centered">
                    <h2>Get Your Coffee QR Code</h2>
                    <form action="/generate" method="POST">
                        <input type="text" name="firstName" placeholder="First Name" required>
                        <input type="text" name="lastName" placeholder="Last Name" required>
                        <input type="email" name="email" placeholder="Email" required>
                        <button type="submit">Generate QR Code</button>
                    </form>

                    <% if (qrCode) { %>
                        <div class="qr-output">
                            <h3>Your QR Code:</h3>
                            <img src="<%= qrCode %>" alt="QR Code">
                        </div>
                        <% } %>
                </div>
            </section>
            <section class="is-pinned" id="locations-hero">
                <div class="centered">

                    <h2>Come visit us</h2>
                </div>
                <div class="row">
                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card">
                                <div class="card-body">
                                    <img src="/images/location-4.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #2F5249;">
                                    <h3>244 W. 57th St.</h3>
                                    <h3>Newville</h3>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card">
                                <div class="card-body">
                                    <img src="/images/location-1.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #2F5249;">
                                    <h3>89 North 8th Blvd.</h3>
                                    <h3>Brookside</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card parent">
                                <div class="card-body">
                                    <img class="my-img" src="/images/location-3.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #2F5249;">
                                    <h3>150 W. 45th St.</h3>
                                    <h3>Westbridge</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card">
                                <div class="card-body">
                                    <img src="/images/location-2.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #2F5249;">
                                    <h3>38 Oakwood Dr.</h3>
                                    <h3>Crestview</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- Modal Container -->
            <div id="myModal" class="modal">
                <div class="modal-content">
                    <span class="close-btn">&times;</span>
                    <h2>Modal Title</h2>
                    <p>This is a simple modal window.</p>
                </div>
            </div>
            </section>
            <section id="footer-hero">
                <div class="row" style="padding: 100px 0;">
                    <div class="container">
                        <h2>📹 @joescoffee</h2>
                    </div>
                </div>
        </main>
        <%- include('partials/footer') %>
            <script src="script.js"></script>
</body>

</html>
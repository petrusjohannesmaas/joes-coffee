<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= pageTitle %> | Coffee Shop
    </title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/layout.css">
</head>

<body>
    <%- include('partials/navbar', { pageHeading }) %>
        <main>
            <section class="product-hero is-pinned">
                <div class="row">
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/bag.png" alt="Coffee bag">
                            <h4>Blend 1</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/bag.png" alt="Coffee bag">
                            <h4>Blend 2</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-md-4 col-4">
                        <div class="container product">
                            <img src="/images/bag.png" alt="Coffee bag">
                            <h4>Blend 3</h4>
                            <h5>$123.00</h5>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="container">
                        <a class="button" href="#shop">SHOP COFFEE</a>
                    </div>
                </div>
                </div>
            </section>
            <section class="is-pinned">
                <div class="about-hero">
                    <div class="centered">
                        <h2>Get Cafe coffee, on your doorstep, at your leisure.</h2>
                        <a class="button">LEARN MORE</a>
                    </div>
                </div>
            </section>
            <section class="is-pinned">
                <div class="centered">

                    <h2>Come visit us</h2>
                </div>
                <div class="row">
                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card">
                                <div class="card-body">
                                    <img src="/images/location-4.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #007BFF;">
                                    <h3>412 W. 74th St.</h3>
                                    <h3>Borroughville</h3>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card">
                                <div class="card-body">
                                    <img src="/images/location-2.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #007BFF;">
                                    <h3>412 W. 74th St.</h3>
                                    <h3>Borroughville</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card parent">
                                <div class="card-body">
                                    <img class="my-img" src="/images/location-3.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #007BFF;">
                                    <h3>412 W. 74th St.</h3>
                                    <h3>Borroughville</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col col-sm-12 col-6">
                        <div class="container">
                            <div class="card">
                                <div class="card-body">
                                    <img src="/images/location-4.png" alt="Location">
                                </div>
                                <div class="card-footer centered" style="background-color: #007BFF;">
                                    <h3>412 W. 74th St.</h3>
                                    <h3>Borroughville</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section>
                <div class="row" style="padding: 100px 0;">
                    <div class="container">
                        <h2>📹 @cafecoffee</h2>
                    </div>
                </div>
            </section>
        </main>
        <%- include('partials/footer') %>
            <script src="script.js"></script>
</body>

</html>